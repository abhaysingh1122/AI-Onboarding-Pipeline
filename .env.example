# ─── Frontend (baked into bundle at build time) ───
# Public identifiers — safe to commit, visible in browser network requests
VITE_TAVUS_PERSONA_ID=pe01f310e034
VITE_TAVUS_REPLICA_ID=r5dc7c7d0bcb

# Proxy URL — leave empty for same-origin (combined server)
# Only set if frontend and API run on different origins
VITE_TAVUS_PROXY_URL=

# ─── Server-side only (never exposed to browser) ───
# Get from Tavus dashboard: https://platform.tavus.io/
TAVUS_API_KEY=your_tavus_api_key_here
